{
  "expo": {
    "name": "AIRPLANE",
    "slug": "airplane",
    "scheme": "airplane",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.airplane.mobile"
    },
    "android": {
      "package": "app.airplane.mobile"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
